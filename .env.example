# =============================================================================
# EMR CRM Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# DJANGO CORE SETTINGS
# -----------------------------------------------------------------------------

# Set to False in production
DEBUG=True

# Generate a new secret key for production:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-change-in-production

# Comma-separated list of allowed hostnames
# Example: ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# PostgreSQL connection URL
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:password@localhost:5432/emr_crm

# -----------------------------------------------------------------------------
# CSRF PROTECTION (Required for production behind proxy/HTTPS)
# -----------------------------------------------------------------------------

# Comma-separated list of trusted origins for CSRF
# Include https:// prefix
# Example: CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=

# -----------------------------------------------------------------------------
# PDF GENERATION
# -----------------------------------------------------------------------------

# How long signed PDF URLs remain valid (in seconds)
# Default: 60 (1 minute) - enough time for Playwright to fetch the page
PDF_URL_EXPIRY_SECONDS=60

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# -----------------------------------------------------------------------------

# Use console backend for development (prints emails to terminal)
# Use SMTP backend for production
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP settings (for production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Default "From" address for outgoing emails
DEFAULT_FROM_EMAIL=Elektro Master Repairs <noreply@elektromaster.com>

# -----------------------------------------------------------------------------
# PRODUCTION SECURITY SETTINGS
# -----------------------------------------------------------------------------
# Enable these when deploying to production with HTTPS

# Redirect all HTTP requests to HTTPS
SECURE_SSL_REDIRECT=False

# Only send cookies over HTTPS
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# HTTP Strict Transport Security (HSTS)
# Set to 31536000 (1 year) for production
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Prevent MIME-sniffing
SECURE_CONTENT_TYPE_NOSNIFF=True

# -----------------------------------------------------------------------------
# PRODUCTION CHECKLIST
# -----------------------------------------------------------------------------
# Before deploying to production, ensure:
# 
# 1. [ ] DEBUG=False
# 2. [ ] SECRET_KEY is unique and secure
# 3. [ ] ALLOWED_HOSTS includes your domain
# 4. [ ] CSRF_TRUSTED_ORIGINS includes https://yourdomain.com
# 5. [ ] Database is PostgreSQL (not SQLite)
# 6. [ ] Email settings are configured for real SMTP
# 7. [ ] SECURE_SSL_REDIRECT=True (if using HTTPS)
# 8. [ ] SESSION_COOKIE_SECURE=True (if using HTTPS)
# 9. [ ] CSRF_COOKIE_SECURE=True (if using HTTPS)
# 10. [ ] SECURE_HSTS_SECONDS=31536000 (if using HTTPS)
# 11. [ ] Static files collected: python manage.py collectstatic
# 12. [ ] Migrations applied: python manage.py migrate